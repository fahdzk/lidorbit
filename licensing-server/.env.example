# Stripe API Keys (Retrieve these from your Stripe Dashboard)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PRICE_ID=your_stripe_price_id_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Brevo SMTP Configuration (Get details from Brevo: Transactional -> SMTP & API)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login_email_here
SMTP_PASS=your_brevo_smtp_key_here
SMTP_FROM="LIDORBIT Support" <your_approved_sender_email_here>

# Maximum number of unique devices allowed per payment session (license)
MAX_DEVICES=1

# Server Port
PORT=3000
